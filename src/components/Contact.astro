---
import type { Lang } from '@/types';
import { t, useTranslatedPath } from '@/i18n';
import Section from './Section.astro';
import data from '@/data/profile/main.json';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const translatePath = useTranslatedPath(lang);
const cvPdf = lang === 'en' ? '/cv-jaime-lerga-en.pdf' : '/cv-jaime-lerga.pdf';
---
<Section id="contact" title={t(lang, 'contact.title')}>
  <div class="grid gap-6 md:grid-cols-2">
    <a
      href={`mailto:${data.email}`}
      class="flex items-center gap-4 rounded-2xl border border-slate-300 p-5 transition hover:border-slate-400 dark:border-slate-800 dark:hover:border-slate-600"
    >
      <span class="flex h-10 w-10 items-center justify-center rounded-full bg-accent-100 text-accent-700 dark:bg-accent-800/50 dark:text-accent-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
      </span>
      <div>
        <div class="text-sm text-slate-600 dark:text-slate-400">{t(lang, 'contact.email')}</div>
        <div class="font-semibold text-accent-700 dark:text-accent-300">{data.email}</div>
      </div>
    </a>

    <a
      href={data.links.linkedin}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-4 rounded-2xl border border-slate-300 p-5 transition hover:border-slate-400 dark:border-slate-800 dark:hover:border-slate-600"
    >
      <span class="flex h-10 w-10 items-center justify-center rounded-full bg-accent-100 text-accent-700 dark:bg-accent-800/50 dark:text-accent-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </span>
      <div>
        <div class="text-sm text-slate-600 dark:text-slate-400">{t(lang, 'contact.linkedin')}</div>
        <div class="font-semibold text-accent-700 dark:text-accent-300">linkedin.com/in/jlerga</div>
      </div>
    </a>

    <a
      href={data.links.github}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-4 rounded-2xl border border-slate-300 p-5 transition hover:border-slate-400 dark:border-slate-800 dark:hover:border-slate-600"
    >
      <span class="flex h-10 w-10 items-center justify-center rounded-full bg-accent-100 text-accent-700 dark:bg-accent-800/50 dark:text-accent-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.419-1.305.762-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
      </span>
      <div>
        <div class="text-sm text-slate-600 dark:text-slate-400">{t(lang, 'contact.github')}</div>
        <div class="font-semibold text-accent-700 dark:text-accent-300">github.com/Rivet92</div>
      </div>
    </a>

    <div class="flex items-start gap-4 rounded-2xl border border-slate-300 p-5 dark:border-slate-800">
      <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-accent-100 text-accent-700 dark:bg-accent-800/50 dark:text-accent-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M12 18v-6"/><path d="m9 15 3 3 3-3"/></svg>
      </span>
      <div>
        <div class="text-sm text-slate-600 dark:text-slate-400">{t(lang, 'contact.cv')}</div>
        <div class="flex gap-3 font-semibold text-accent-700 dark:text-accent-300">
          <a href={translatePath('/cv')} class="hover:underline">{t(lang, 'contact.cvOnline')}</a>
          <span class="text-slate-400">·</span>
          <a href={cvPdf} download class="hover:underline">{t(lang, 'contact.cvDownload')}</a>
        </div>
      </div>
    </div>
  </div>
</Section>