---
import type { Lang } from '@/types';
import { t, getLocalized } from '@/i18n';
import aboutData from '@/data/about/main.json';
import skillsData from '@/data/skills.json';
import p from '@/data/profile/main.json';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const experienceFiles = import.meta.glob('@/data/experience/*.json', { eager: true });
const educationFiles = import.meta.glob('@/data/education/*.json', { eager: true });

const experience = Object.values(experienceFiles).map((mod) => mod.default);
const education = Object.values(educationFiles).map((mod) => mod.default);
experience.sort((a, b) => a.order - b.order);
education.sort((a, b) => a.order - b.order);

function formatDate(value: string | null) {
  if (!value) return t(lang, 'experience.current');
  const [year, month] = value.split('-');
  return new Date(Number(year), Number(month) - 1).toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-US', { year: 'numeric', month: 'short' });
}
---
<article class="cv-card mx-auto max-w-4xl px-6 py-10 md:py-12">
  <header class="mb-8 border-b border-slate-400 pb-6 dark:border-slate-700">
    <div class="flex flex-col items-center gap-6 md:flex-row md:items-start md:text-left print:flex-row print:items-start print:text-left">
      <div class="initials-circle flex h-24 w-24 shrink-0 items-center justify-center rounded-full bg-accent-600 text-4xl font-bold text-white dark:bg-accent-400 dark:text-accent-950 md:h-28 md:w-28">
        JL
      </div>
      <div class="flex-1 text-center md:text-left print:text-left">
        <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100 md:text-4xl">{p.name}</h1>
        <p class="mt-1 text-lg font-medium text-slate-700 dark:text-slate-300">{getLocalized(p.role, lang)}</p>
        <p class="mt-1 text-sm text-slate-700 dark:text-slate-400">{p.location}</p>
        <div class="mt-3 flex flex-wrap justify-center gap-3 md:justify-start print:justify-start text-sm">
          <a href={`mailto:${p.email}`} class="font-medium text-accent-700 hover:text-accent-800 hover:underline dark:text-accent-300 dark:hover:text-accent-200">{p.email}</a>
          <span class="text-slate-400">·</span>
          <a href={p.links.linkedin} class="font-medium text-accent-700 hover:text-accent-800 hover:underline dark:text-accent-300 dark:hover:text-accent-200">linkedin.com/in/jlerga</a>
          <span class="text-slate-400">·</span>
          <a href={p.links.github} class="font-medium text-accent-700 hover:text-accent-800 hover:underline dark:text-accent-300 dark:hover:text-accent-200">github.com/Rivet92</a>
        </div>
      </div>
    </div>
  </header>

  <section class="mb-8">
    <h2 class="mb-3 text-xl font-bold uppercase tracking-wide text-slate-900 dark:text-slate-100">{t(lang, 'cv.summary')}</h2>
    <p class="text-justify text-slate-700 dark:text-slate-300">{getLocalized(aboutData.paragraphs[0], lang)} {getLocalized(aboutData.paragraphs[1], lang)}</p>
  </section>

  <section class="mb-8">
    <h2 class="mb-4 text-xl font-bold uppercase tracking-wide text-slate-900 dark:text-slate-100">{t(lang, 'cv.experience')}</h2>
    <div class="space-y-6">
      {experience.map((item) => (
        <div class="cv-card">
          <div class="flex flex-wrap items-baseline justify-between gap-2">
            <h3 class="text-lg font-bold text-slate-900 dark:text-slate-100">{getLocalized(item.role, lang)} · {item.company}</h3>
            <span class="text-sm text-slate-700 dark:text-slate-400">{formatDate(item.start)} — {formatDate(item.end)}</span>
          </div>
          <p class="text-sm italic text-slate-700 dark:text-slate-400">{t(lang, 'experience.client')}: {getLocalized(item.client, lang)} · {getLocalized(item.mode, lang)}</p>
          <p class="mt-2 text-justify text-sm text-slate-700 dark:text-slate-300">{getLocalized(item.summary, lang)}</p>
          <div class="mt-2 flex flex-wrap gap-1.5">
            {item.stack.map((tech) => (
              <span class="text-xs text-slate-700 dark:text-slate-400">{tech}{item.stack.indexOf(tech) < item.stack.length - 1 ? ',' : ''}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="mb-8">
    <h2 class="mb-4 text-xl font-bold uppercase tracking-wide text-slate-900 dark:text-slate-100">{t(lang, 'cv.education')}</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {education.map((item) => (
        <div class="cv-card">
          <h3 class="font-bold text-slate-900 dark:text-slate-100">{getLocalized(item.degree, lang)}</h3>
          <p class="text-sm text-slate-700 dark:text-slate-400">{item.school}</p>
          <p class="text-sm text-slate-700 dark:text-slate-700">{formatDate(item.start)} — {formatDate(item.end)}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="mb-8">
    <h2 class="mb-4 text-xl font-bold uppercase tracking-wide text-slate-900 dark:text-slate-100">{t(lang, 'cv.skills')}</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {skillsData.categories.map((category) => (
        <div>
          <h3 class="mb-1 font-semibold text-slate-900 dark:text-slate-100">{getLocalized(category.name, lang)}</h3>
          <p class="text-sm text-slate-700 dark:text-slate-300">{category.items.map((item) => getLocalized(item, lang)).join(', ')}</p>
        </div>
      ))}
    </div>
  </section>
</article>

<script is:inline>
  (function() {
    const stored = localStorage.getItem('theme');
    const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const theme = stored || (systemDark ? 'dark' : 'light');
    document.documentElement.setAttribute('data-theme', theme);
  })();
</script>

<style>
  @media print {
    article.cv-card {
      break-inside: auto;
    }
    section {
      break-inside: avoid;
    }
    a {
      color: #4f46e5 !important;
      text-decoration: none !important;
    }
    .initials-circle {
      print-color-adjust: exact;
      -webkit-print-color-adjust: exact;
      color: white !important;
    }
    h2 {
      color: #4f46e5 !important;
    }
  }
</style>