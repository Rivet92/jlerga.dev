---
import type { Lang } from '@/types';
import { getLocalized } from '@/i18n';
import { inlineMarkdown } from '@/utils/markdown';
import Section from './Section.astro';
import aboutData from '@/data/about/main.json';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const title = getLocalized(aboutData.title, lang);
const paragraphs = aboutData.paragraphs.map((p) => inlineMarkdown(getLocalized(p, lang)));
---
<Section id="about" title={title}>
  <div class="space-y-6 text-justify text-lg leading-relaxed text-slate-700 dark:text-slate-300">
    {paragraphs.map((html) => <p set:html={html} />)}
  </div>
</Section>