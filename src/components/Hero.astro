---
import type { Lang } from '@/types';
import { t, getLocalized, useTranslatedPath } from '@/i18n';
import { inlineMarkdown } from '@/utils/markdown';
import data from '@/data/profile/main.json';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const translatePath = useTranslatedPath(lang);
---
<section class="hero-section snap-section mx-auto max-w-5xl px-6 pt-4 pb-8 md:pt-24 md:pb-24">
  <div class="flex flex-col items-center gap-8 md:flex-row md:items-center">
    <div class="flex h-24 w-24 shrink-0 items-center justify-center rounded-full bg-accent-600 text-3xl font-bold text-white dark:bg-accent-400 dark:text-accent-950 md:h-32 md:w-32 md:text-4xl">
      JL
    </div>
    <div class="space-y-4 text-center md:text-left">
      <h1 class="text-4xl font-semibold tracking-tight text-slate-900 dark:text-slate-100 md:text-6xl">
        {data.name}
      </h1>
      <p class="text-xl font-medium text-slate-700 dark:text-slate-300 md:text-2xl">
        {getLocalized(data.role, lang)}
      </p>
      <p class="max-w-2xl text-lg text-slate-700 dark:text-slate-400" set:html={inlineMarkdown(getLocalized(data.tagline, lang))}>
      </p>
      <div class="flex flex-wrap gap-3 pt-2 justify-center md:justify-start">
        <a
          href="#contact"
          class="rounded-full bg-accent-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-accent-700 dark:bg-accent-400 dark:text-accent-950 dark:hover:bg-accent-300"
        >
          {t(lang, 'hero.cta.contact')}
        </a>
        <a
          href={translatePath('/cv')}
          class="rounded-full border border-accent-300 px-5 py-2.5 text-sm font-semibold text-accent-700 hover:bg-accent-50 dark:border-accent-700 dark:text-accent-300 dark:hover:bg-accent-900/30"
        >
          {t(lang, 'hero.cta.cv')}
        </a>
      </div>
    </div>
  </div>
</section>