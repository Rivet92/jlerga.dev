---
import type { Lang } from '@/types';
import { t, getLocalized } from '@/i18n';
import { inlineMarkdown } from '@/utils/markdown';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const educationFiles = import.meta.glob('@/data/education/*.json', { eager: true });
const items = Object.values(educationFiles).map((mod) => mod.default);
items.sort((a, b) => a.order - b.order);

function formatDate(value: string) {
  const [year, month] = value.split('-');
  const date = new Date(Number(year), Number(month) - 1);
  return date.toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-US', { year: 'numeric', month: 'short' });
}
---
<div class="snap-section mx-auto max-w-5xl px-6 pb-16 pt-8 md:pb-24 md:pt-4">
    <h2 class="mb-10 text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100">{t(lang, 'education.title')}</h2>
    <div class="grid gap-6 md:grid-cols-2">
      {items.map((item) => (
        <article class="rounded-2xl border border-slate-300 p-5 dark:border-slate-800">
          <div class="text-sm text-slate-700 dark:text-slate-400">
            {formatDate(item.start)} — {formatDate(item.end)}
          </div>
          <h4 class="mt-1 text-lg font-bold text-slate-900 dark:text-slate-100">{getLocalized(item.degree, lang)}</h4>
          <p class="text-sm text-slate-700 dark:text-slate-400">{item.school}</p>
          <p class="mt-2 text-sm text-slate-700 dark:text-slate-300" set:html={inlineMarkdown(getLocalized(item.description, lang))}></p>
        </article>
      ))}
    </div>
  </div>
