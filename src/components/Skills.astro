---
import type { Lang } from '@/types';
import { t, getLocalized } from '@/i18n';
import Section from './Section.astro';
import skillsData from '@/data/skills.json';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---
<Section id="skills" title={t(lang, 'skills.title')}>
  <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
    {skillsData.categories.map((category) => (
      <div class="rounded-2xl border border-slate-300 p-5 dark:border-slate-800">
        <h3 class="mb-3 text-lg font-bold text-slate-900 dark:text-slate-100">{getLocalized(category.name, lang)}</h3>
        <div class="flex flex-wrap gap-2">
          {category.items.map((item) => (
            <span class="rounded-full bg-accent-100 px-3 py-1 text-sm font-medium text-accent-700 dark:bg-slate-800 dark:text-slate-300">{getLocalized(item, lang)}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</Section>