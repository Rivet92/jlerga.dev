---
import type { Lang } from '@/types';
import { t, getLocalized } from '@/i18n';
import { inlineMarkdown } from '@/utils/markdown';
import Section from './Section.astro';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const experienceFiles = import.meta.glob('@/data/experience/*.json', { eager: true });
const items = Object.values(experienceFiles).map((mod) => mod.default);
items.sort((a, b) => a.order - b.order);

function formatDate(value: string | null) {
  if (!value) return t(lang, 'experience.current');
  const [year, month] = value.split('-');
  const date = new Date(Number(year), Number(month) - 1);
  return date.toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-US', { year: 'numeric', month: 'short' });
}
---
<Section id="experience" title={t(lang, 'experience.title')}>
  <div class="relative">
    <!-- línea vertical global -->
    <div class="absolute left-[9px] top-2.5 bottom-2.5 w-0.5 bg-slate-200 dark:bg-slate-800"></div>

    <div class="space-y-10">
      {items.map((item) => (
        <div class="relative flex gap-6">
          <!-- columna del punto -->
          <div class="relative z-10 flex w-5 shrink-0 justify-center pt-0.5">
            <span class="h-5 w-5 rounded-full border-4 border-accent-100 bg-slate-900 dark:border-slate-950 dark:bg-white"></span>
          </div>

          <!-- contenido -->
          <article class="flex-1">
            <div class="flex flex-wrap items-center gap-2 text-sm text-slate-700 dark:text-slate-400">
              <time datetime={item.start}>{formatDate(item.start)}</time>
              <span>—</span>
              <time datetime={item.end ?? undefined}>{formatDate(item.end)}</time>
              <span>·</span>
              <span>{item.location}</span>
              <span>·</span>
              <span>{getLocalized(item.mode, lang)}</span>
            </div>
            <h3 class="mt-2 text-xl font-bold text-slate-900 dark:text-slate-100">
              {getLocalized(item.role, lang)} · {item.company}
            </h3>
            <p class="text-sm font-medium text-slate-700 dark:text-slate-400">
              {t(lang, 'experience.client')}: {getLocalized(item.client, lang)}
            </p>
            <p class="mt-3 text-justify text-slate-700 dark:text-slate-300" set:html={inlineMarkdown(getLocalized(item.summary, lang))}></p>
            <div class="mt-3 flex flex-wrap gap-2">
              {item.stack.map((tech) => (
                <span class="rounded-full bg-accent-100 px-3 py-1 text-xs font-medium text-accent-700 dark:bg-slate-800 dark:text-slate-300">{tech}</span>
              ))}
            </div>
          </article>
        </div>
      ))}
    </div>
  </div>
</Section>