<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Jaime Lerga Marquina</title>
    <meta http-equiv="refresh" content="0; url=/es" />
    <script is:inline>
      (function() {
        const lang = navigator.language || navigator.userLanguage || 'es';
        window.location.replace(lang.toLowerCase().startsWith('es') ? '/es' : '/en');
      })();
    </script>
  </head>
  <body>
    <noscript>
      <p>Redirigiendo a <a href="/es">/es</a>...</p>
    </noscript>
  </body>
</html>